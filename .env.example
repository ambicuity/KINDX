# KINDX runtime configuration example
# Copy values into your local .env or shell environment. Do not commit real secrets.

# MCP HTTP authentication
# Generate with: openssl rand -hex 32
KINDX_MCP_TOKEN=

# Local model execution
KINDX_LLM_BACKEND=local
KINDX_CPU_ONLY=0
KINDX_EMBED_MODEL=hf:ggml-org/embeddinggemma-300M-GGUF/embeddinggemma-300M-Q8_0.gguf
KINDX_RERANK_MODEL=hf:ggml-org/Qwen3-Reranker-0.6B-Q8_0-GGUF/qwen3-reranker-0.6b-q8_0.gguf
KINDX_GENERATE_MODEL=hf:LiquidAI/LFM2.5-1.2B-Instruct-GGUF/LFM2.5-1.2B-Instruct-Q8_0.gguf
KINDX_EXPAND_CONTEXT_SIZE=2048
KINDX_RERANK_CONTEXT_SIZE=4096

# Remote OpenAI-compatible backend, for example Ollama or LM Studio
KINDX_OPENAI_BASE_URL=http://localhost:11434/v1
KINDX_OPENAI_API_KEY=
KINDX_OPENAI_EMBED_MODEL=nomic-embed-text
KINDX_OPENAI_GENERATE_MODEL=qwen2.5-coder:1.5b
KINDX_OPENAI_RERANK_MODEL=qwen3-reranker

# Storage and encryption
KINDX_CONFIG_DIR=
XDG_CACHE_HOME=
KINDX_ENCRYPTION_KEY=
KINDX_SQLITE_DRIVER=

# Query/runtime controls
KINDX_QUERY_TIMEOUT_MS=0
KINDX_INFLIGHT_DEDUPE=join
KINDX_QUERY_REPLAY_DIR=
KINDX_RERANK_TIMEOUT_MS=
KINDX_RERANK_QUEUE_LIMIT=
KINDX_RERANK_CONCURRENCY=
KINDX_RERANK_DROP_POLICY=timeout_fallback
KINDX_VECTOR_FANOUT_WORKERS=4

# Sharding and ANN
KINDX_ANN_ENABLE=1
KINDX_ANN_PROBE_COUNT=4
KINDX_ANN_SHORTLIST=

# Document extraction
KINDX_EXTRACTOR_PDF=1
KINDX_EXTRACTOR_DOCX=1
KINDX_EXTRACTOR_FALLBACK_POLICY=fallback

# Optional Arch integration
KINDX_ARCH_ENABLED=0
KINDX_ARCH_AUGMENT_ENABLED=0
KINDX_ARCH_AUTO_REFRESH_ON_UPDATE=0
KINDX_ARCH_REPO_PATH=./tmp/arch
KINDX_ARCH_PYTHON_BIN=python3
KINDX_ARCH_COLLECTION=__arch
KINDX_ARCH_ARTIFACT_DIR=
KINDX_ARCH_MIN_CONFIDENCE=INFERRED
KINDX_ARCH_MAX_HINTS=3
