# Auto detect text files and perform LF normalization
* text=auto

# TypeScript
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Training data (treat as binary to avoid line ending issues)
*.jsonl binary

# Lock files
bun.lock binary

# Models
*.gguf binary filter=lfs diff=lfs merge=lfs -text
