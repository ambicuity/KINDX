{
  "name": "@ambicuity/kindx-client",
  "version": "0.1.0",
  "description": "Typed TypeScript client for KINDX MCP/HTTP APIs",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --reporter=verbose specs/"
  },
  "dependencies": {
    "@ambicuity/kindx-schemas": "file:../kindx-schemas"
  }
}
